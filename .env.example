# .env.example — 100% Free Tier Configuration
# نسخ هذا الملف إلى .env واملأ القيم (كلها اختيارية)

# App
APP_NAME=Flaha — الوكيل الفلاحي الذكي
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database — اختر sqlite (مجاني, افتراضي) أو postgresql
DATABASE_TYPE=sqlite
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/flaha

# AI — NVIDIA / OpenAI-compatible (مجاني ∞, استخدم وضع المحاكاة بدون مفتاح)
AI_API_KEY=
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_MODEL=minimaxai/minimax-m2.7

# WhatsApp (Meta Cloud API — مجاني 1000 محادثة/شهر)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=flaha-webhook-2026
WHATSAPP_ACCESS_TOKEN=

# USSD — مجاني مع اتفاق مع المتصل
USSD_API_KEY=
USSD_SHORT_CODE=*233#

# Baridi Mob (يدعم وضع المحاكاة)
BARIDI_MOB_API_KEY=
BARIDI_MOB_MERCHANT_ID=
BARIDI_MOB_SECRET=

# Weather — OpenWeatherMap (مجاني 1000 طلب/يوم)
OPENWEATHER_API_KEY=

# Yalidine (يدعم وضع المحاكاة)
YALIDINE_API_KEY=
YALIDINE_SECRET=

# JWT
JWT_SECRET=flaha-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
